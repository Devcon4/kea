# ── Required ──────────────────────────────────────────────
TARGET_URL=https://example.com          # Site to crawl / chaos-test

# ── LLM ──────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434/v1  # OpenAI-compatible endpoint (Ollama default)
LLM_API_KEY=ollama                      # API key (use "ollama" for local Ollama)
LLM_MODEL=gemma4                        # Model name

# ── Exploration ──────────────────────────────────────────
MAX_PAGES=50                            # Stop after visiting this many pages
MAX_FINDINGS=100                        # Max findings to record
HEADLESS=true                           # Run browser headless (set "false" to watch)

# ── Server ───────────────────────────────────────────────
PORT=3000                               # HTTP API port

# ── Database ─────────────────────────────────────────────
DB_PATH=kea.db                          # SQLite database file path

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=info                          # pino log level (trace/debug/info/warn/error/fatal)
NODE_ENV=production                     # "development" for pretty-printed logs
SEQ_URL=http://localhost:5341           # Seq ingestion URL (omit to disable)
# SEQ_API_KEY=                          # Seq API key (optional for local)
