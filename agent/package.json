{
  "name": "@kea/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --ssr src/index.ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "echo 'Database managed by @kea/api'",
    "db:migrate": "echo 'Database managed by @kea/api'",
    "db:studio": "echo 'Database managed by @kea/api'"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.2.0",
    "@hono/node-server": "^1.19.12",
    "@kea/shared": "file:../shared",
    "hono": "^4.12.11",
    "ollama": "^0.6.3",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "pino-seq": "^4.0.0",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
