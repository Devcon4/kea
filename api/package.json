{
  "name": "@kea/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist/index.js --sourcemap --packages=bundle --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@kea/shared": "file:../shared",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.11",
    "pino": "^10.3.1",
    "pino-seq": "^4.0.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260412.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
