<h1>Our Products</h1>
<p>Browse our curated selection of testing tools and accessories.</p>
<div class="product-grid">
  <% products.forEach(function(product) { %>
  <div class="product-card">
    <img src="<%= product.image %>" alt="<%= product.name %>">
    <div class="info">
      <h2><%= product.name %></h2>
      <p class="price">$<%= product.price.toFixed(2) %></p>
      <a href="/product/<%= product.id %>">View Details &rarr;</a>
    </div>
  </div>
  <% }); %>
</div>
