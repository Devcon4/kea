<div class="product">
  <img src="<%= product.detailImage %>" alt="<%= product.name %>">
  <div class="details">
    <h1><%= product.name %></h1>
    <p class="price">$<%= product.price.toFixed(2) %></p>
    <p><%= product.description %></p>
    <p><%= product.features %></p>
    <a href="/cart" class="btn">Add to Cart</a>
    <a href="/" class="back">&larr; Back to products</a>
  </div>
</div>
